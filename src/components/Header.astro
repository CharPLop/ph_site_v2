---
import { nav, site } from "@/config/site";
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? current === "/" : current.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[color-mix(in_srgb,var(--color-cream)_88%,transparent)] backdrop-blur-md">
  <nav class="container-ph flex h-[68px] items-center justify-between" aria-label="Principale">
    <a href="/" class="flex items-center gap-2.5" aria-label={`${site.nome} — home`}>
      <img src={site.logo} alt={`${site.nome} — logo`} width="61" height="56" class="h-14 w-auto object-contain" />
      <span class="font-[family-name:var(--font-display)] text-xl leading-none text-[var(--color-ink)]">
        Psiche Holos
      </span>
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="p-2 md:hidden"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/>
      </svg>
    </button>

    <ul
      id="nav-menu"
      class="absolute left-0 right-0 top-full hidden flex-col gap-1 border-b border-[var(--color-line)] bg-[var(--color-cream)] p-4 md:static md:flex md:flex-row md:items-center md:gap-7 md:border-0 md:bg-transparent md:p-0"
    >
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              "link-underline text-[0.95rem] font-semibold text-[var(--color-ink-soft)] hover:text-[var(--color-verde)]",
              isActive(item.href) && "!text-[var(--color-verde)]",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="mt-2 md:mt-0">
        <a href="/contatti/" class="btn btn-primary !py-2.5 !px-5 text-sm">Prenota</a>
      </li>
    </ul>
  </nav>

  <script>
    const t = document.getElementById("nav-toggle");
    const m = document.getElementById("nav-menu");
    if (t && m) {
      const close = () => { m.classList.add("hidden"); m.classList.remove("flex"); t.setAttribute("aria-expanded", "false"); t.setAttribute("aria-label", "Apri menu"); };
      const open = () => { m.classList.remove("hidden"); m.classList.add("flex"); t.setAttribute("aria-expanded", "true"); t.setAttribute("aria-label", "Chiudi menu"); };
      t.addEventListener("click", () => (t.getAttribute("aria-expanded") === "true" ? close() : open()));
      m.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
    }
  </script>
</header>
