---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { team } from "@/config/site";
---

<BaseLayout
  title="Il team"
  description="Le tre professioniste di Psiche Holos a Brescia: Ilenia Tagliaferro (psicoterapeuta CBT), Anna Marini (psicoterapeuta) e Valentina Nicolai (psicologa scolastica)."
  path="/team/"
>
  <section class="container-ph pt-16 md:pt-24">
    <p class="kicker">Il team</p>
    <h1 class="mt-3 text-[clamp(2.4rem,5vw,3.6rem)]">Tre professioniste, un'unica missione</h1>
    <p class="mt-5 max-w-2xl text-lg text-[var(--color-ink-soft)]">
      Competenze e approcci diversi che si incontrano in un'unica cura: il
      benessere della persona nella sua totalità.
    </p>
  </section>

  <section class="container-ph mt-12 grid gap-6 md:grid-cols-3">
    {team.map((m) => (
      <article class="flex flex-col overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-line)] bg-[var(--color-white-warm)]">
        {m.foto && (
          <img
            src={m.foto}
            alt={`Ritratto di ${m.nome}`}
            width="660"
            height="825"
            loading="lazy"
            class="aspect-[4/5] w-full object-cover object-center"
          />
        )}
        <div class="flex flex-1 flex-col p-7">
          <h2 class="text-xl">{m.nome}</h2>
          <p class="text-sm font-semibold text-[var(--color-verde)]">{m.ruolo}</p>

          <div class="mt-4 flex-1">
            <p class="text-[0.95rem] text-[var(--color-ink-soft)]">{m.bioBreve}</p>
            <a
              href={m.sitoWeb ?? `/team/${m.slug}/`}
              target={m.sitoWeb ? "_blank" : undefined}
              rel={m.sitoWeb ? "noopener" : undefined}
              class="link-underline mt-3 inline-block text-sm font-semibold text-[var(--color-verde)]"
            >
              {m.sitoWeb ? "Scopri di più sul suo sito →" : "Approfondisci →"}
            </a>
          </div>

          <div class="mt-5 flex flex-wrap gap-2 text-sm">
            <a href={`tel:+39${m.telefonoDisplay.replace(/\s/g, "")}`} class="rounded-full bg-[var(--color-cream-deep)] px-3 py-1 hover:bg-[var(--color-sage)]">
              📞 {m.telefonoDisplay}
            </a>
            <a href={m.whatsapp} target="_blank" rel="noopener" class="rounded-full bg-[var(--color-cream-deep)] px-3 py-1 hover:bg-[var(--color-sage)]">
              💬 WhatsApp
            </a>
            <a href={m.instagram} target="_blank" rel="noopener" class="rounded-full bg-[var(--color-cream-deep)] px-3 py-1 hover:bg-[var(--color-sage)]">
              📷 Instagram
            </a>
          </div>
        </div>
      </article>
    ))}
  </section>

</BaseLayout>
