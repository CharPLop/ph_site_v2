---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { servizi, fasce } from "@/config/site";
---

<BaseLayout
  title="Servizi"
  description="I servizi dello studio Psiche Holos a Brescia: psicoterapia individuale, percorsi di gruppo, terapia online, supporto scolastico, sostegno alla genitorialità, incontri protetti."
  path="/servizi/"
>
  <section class="container-ph pt-16 md:pt-24">
    <p class="kicker">Cosa facciamo</p>
    <h1 class="mt-3 text-[clamp(2.4rem,5vw,3.6rem)]">Percorsi pensati per ogni esigenza</h1>
    <p class="mt-5 max-w-2xl text-lg text-[var(--color-ink-soft)]">
      Ci prendiamo cura della persona nella sua totalità, con metodologie diverse
      nel rispetto dell'unicità di ciascuno.
    </p>
  </section>

  <section class="container-ph mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {servizi.map((s) => (
      <article
        id={s.slug}
        class="scroll-mt-24 rounded-[var(--radius-md)] border border-[var(--color-line)] bg-[var(--color-white-warm)] p-7"
      >
        <span class="text-3xl" aria-hidden="true">{s.icona}</span>
        <h2 class="mt-3 text-xl">{s.titolo}</h2>
        <p class="mt-2 text-[0.95rem] text-[var(--color-ink-soft)]">{s.testo}</p>
      </article>
    ))}
  </section>

  <!-- Fasce d'età -->
  <section class="container-ph mt-16">
    <p class="kicker">Per ogni fase della vita</p>
    <h2 class="mt-3 text-[clamp(1.7rem,3.5vw,2.4rem)]">Ci prendiamo cura della persona a ogni età</h2>
    <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-5">
      {fasce.map((f) => (
        <div class="rounded-[var(--radius-md)] border border-[var(--color-line)] bg-[var(--color-cream-deep)] p-5 text-center">
          <span class="text-3xl" aria-hidden="true">{f.emoji}</span>
          <p class="mt-2 font-semibold text-[var(--color-verde)]">{f.titolo}</p>
          <p class="text-sm text-[var(--color-ink-soft)]">{f.testo}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-ph mt-14 text-center">
    <a href="/contatti/" class="btn btn-primary">Prenota un colloquio</a>
  </section>
</BaseLayout>
