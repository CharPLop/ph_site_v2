---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { servizi, quandoRivolgersi, site } from "@/config/site";

const servicesLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: servizi.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Service",
      name: s.titolo,
      description: s.descrizione ?? s.testo,
      provider: { "@type": "MedicalBusiness", name: site.nome, url: site.url },
      areaServed: ["Brescia", "Provincia di Brescia"],
    },
  })),
};
---

<BaseLayout
  title="Servizi"
  description="I servizi dello studio Psiche Holos a Brescia: psicoterapia individuale e di gruppo, supporto scolastico, sostegno alla genitorialità, formazione e supervisione, mindfulness e training autogeno, terapia online."
  path="/servizi/"
>
  <section class="container-ph pt-16 md:pt-24">
    <p class="kicker">Cosa facciamo</p>
    <h1 class="mt-3 text-[clamp(2.4rem,5vw,3.6rem)]">Percorsi pensati per ogni esigenza</h1>
    <p class="mt-5 max-w-2xl text-lg text-[var(--color-ink-soft)]">
      Ci prendiamo cura della persona nella sua totalità, con metodologie diverse
      nel rispetto dell'unicità di ciascuno.
    </p>
  </section>

  <section class="container-ph mt-12 space-y-5">
    {servizi.map((s) => (
      <article
        id={s.slug}
        class="scroll-mt-24 rounded-[var(--radius-md)] border border-[var(--color-line)] bg-[var(--color-white-warm)] p-7 md:grid md:grid-cols-[auto_1fr] md:gap-7 md:p-9"
      >
        <span class="text-4xl" aria-hidden="true">{s.icona}</span>
        <div class="mt-3 md:mt-0">
          <h2 class="text-xl">{s.titolo}</h2>
          <p class="mt-2 text-[var(--color-ink-soft)]">{s.descrizione ?? s.testo}</p>
          {s.punti && (
            <ul class="mt-4 grid gap-x-8 gap-y-2 sm:grid-cols-2">
              {s.punti.map((p) => (
                <li class="flex gap-2 text-[0.95rem] text-[var(--color-ink-soft)]">
                  <span class="text-[var(--color-verde)]">•</span><span>{p}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </section>

  <section class="container-ph mt-16">
    <div class="rounded-[var(--radius-lg)] border border-[var(--color-line)] bg-[var(--color-cream-deep)] p-8 md:p-10">
      <p class="kicker">Quando rivolgersi</p>
      <h2 class="mt-3 text-[clamp(1.6rem,3vw,2.1rem)]">Chiedere aiuto è già un primo passo</h2>
      <p class="mt-4 max-w-2xl text-[var(--color-ink-soft)]">{quandoRivolgersi.intro}</p>
      <ul class="mt-6 grid gap-x-8 gap-y-3 sm:grid-cols-2">
        {quandoRivolgersi.motivi.map((m) => (
          <li class="flex gap-3 text-[0.97rem] text-[var(--color-ink-soft)]">
            <span class="mt-1 text-[var(--color-verde)]">•</span><span>{m}</span>
          </li>
        ))}
      </ul>
      <p class="mt-6 max-w-2xl text-[var(--color-ink-soft)]">{quandoRivolgersi.chiusura}</p>
    </div>
  </section>

  <section class="container-ph mt-14 text-center">
    <a href="/contatti/" class="btn btn-primary">Prenota un colloquio</a>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(servicesLd)} />
</BaseLayout>
