---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, sedi, team } from "@/config/site";
const brescia = sedi.find((s) => s.mappaEmbed);
---

<BaseLayout
  title="Contatti"
  description="Contatta lo studio Psiche Holos a Brescia, Via Guido Zadei 60: WhatsApp, email, telefono delle professioniste. Su appuntamento, anche online."
  path="/contatti/"
>
  <section class="container-ph grid gap-12 pt-16 md:grid-cols-2 md:pt-24">
    <div>
      <p class="kicker">Prendi appuntamento</p>
      <h1 class="mt-3 text-[clamp(2.4rem,5vw,3.6rem)]">Il primo passo? Contattaci.</h1>
      <p class="mt-5 max-w-md text-lg text-[var(--color-ink-soft)]">
        Non serve aver chiaro cosa dire. La prima seduta è uno spazio per
        conoscersi. Scrivici e ti ricontatteremo in giornata.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-primary">Scrivici su WhatsApp</a>
        <a href={`mailto:${site.email}`} class="btn btn-ghost">Email</a>
      </div>

      <div class="mt-8 space-y-3 text-sm">
        <a href={`mailto:${site.email}`} class="flex items-center gap-3 link-underline">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-[var(--color-sage)] text-[var(--color-verde)]">✉</span>
          {site.email}
        </a>
        <a href={site.instagram} target="_blank" rel="noopener" class="flex items-center gap-3 link-underline">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-[var(--color-sage)] text-[var(--color-verde)]">◎</span>
          {site.instagramHandle}
        </a>
      </div>

      <div class="mt-8">
        <p class="kicker">Telefono diretto</p>
        <ul class="mt-3 space-y-1.5 text-sm">
          {team.map((m) => (
            <li>
              <span class="text-[var(--color-ink-soft)]">{m.nome.replace("Dott.ssa ", "Dott.ssa ")} — </span>
              <a href={`tel:+39${m.telefonoDisplay.replace(/\s/g, "")}`} class="link-underline font-semibold text-[var(--color-verde)]">{m.telefonoDisplay}</a>
            </li>
          ))}
        </ul>
      </div>

      <p class="mt-8 text-sm text-[var(--color-ink-soft)]">
        Hai dubbi prima di scriverci? Leggi le
        <a href="/faq/" class="link-underline font-semibold text-[var(--color-verde)]">domande frequenti</a>.
      </p>
    </div>

    <div>
      <h2 class="text-2xl">Dove siamo</h2>
      <div class="mt-5 rounded-[var(--radius-md)] border border-[var(--color-line)] bg-[var(--color-white-warm)] p-5">
        <p class="font-semibold text-[var(--color-verde)]">Studio Psiche Holos</p>
        <p class="text-sm text-[var(--color-ink-soft)]">Via Guido Zadei, 60 — 25128 Brescia (BS)</p>
        <p class="mt-1 text-sm text-[var(--color-ink-soft)]">Su appuntamento · anche online</p>
        <p class="mt-1 text-sm text-[var(--color-ink-soft)]">🅿️ Parcheggio disponibile nelle vicinanze</p>
      </div>
      {brescia?.mappaEmbed && (
        <div class="mt-5 overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-line)]">
          <iframe
            src={brescia.mappaEmbed}
            title="Mappa — Studio Psiche Holos, Brescia"
            width="100%"
            height="300"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      )}
    </div>
  </section>

  <!-- FORM CONTATTI -->
  <section class="container-ph mb-4">
    <div class="mx-auto max-w-2xl rounded-[var(--radius-lg)] border border-[var(--color-line)] bg-[var(--color-white-warm)] p-7 md:p-9">
      <p class="kicker">Oppure scrivici direttamente</p>
      <h2 class="mt-3 text-[clamp(1.5rem,3vw,2rem)]">Compila il form, ti ricontatteremo in giornata</h2>

      <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" class="mt-6 space-y-4">
        <input type="hidden" name="access_key" value="TUA_ACCESS_KEY_QUI">
        <input type="hidden" name="subject" value="Nuovo contatto dal sito Psiche Holos">
        <input type="hidden" name="from_name" value="Sito Psiche Holos">
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off">

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-[var(--color-ink-soft)]" for="cf-nome">Nome *</label>
            <input id="cf-nome" type="text" name="name" required placeholder="Il tuo nome"
              class="mt-1.5 w-full rounded-[10px] border border-[var(--color-line)] bg-white px-4 py-2.5 text-[var(--color-ink)] outline-none transition focus:border-[var(--color-verde)] focus:ring-2 focus:ring-[var(--color-sage)]">
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--color-ink-soft)]" for="cf-tel">Telefono *</label>
            <input id="cf-tel" type="tel" name="phone" required placeholder="Es: 333 1234567" pattern="[0-9\s\+]{6,20}" title="Inserisci un numero di telefono valido"
              class="mt-1.5 w-full rounded-[10px] border border-[var(--color-line)] bg-white px-4 py-2.5 text-[var(--color-ink)] outline-none transition focus:border-[var(--color-verde)] focus:ring-2 focus:ring-[var(--color-sage)]">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-[var(--color-ink-soft)]" for="cf-email">Email <span class="font-normal opacity-70">(opzionale)</span></label>
          <input id="cf-email" type="email" name="email" placeholder="La tua email"
            class="mt-1.5 w-full rounded-[10px] border border-[var(--color-line)] bg-white px-4 py-2.5 text-[var(--color-ink)] outline-none transition focus:border-[var(--color-verde)] focus:ring-2 focus:ring-[var(--color-sage)]">
        </div>

        <div>
          <label class="block text-sm font-medium text-[var(--color-ink-soft)]" for="cf-msg">Come possiamo aiutarti? <span class="font-normal opacity-70">(opzionale)</span></label>
          <textarea id="cf-msg" name="message" rows="4" placeholder="Non serve scrivere molto — anche solo 'vorrei informazioni' va benissimo"
            class="mt-1.5 w-full rounded-[10px] border border-[var(--color-line)] bg-white px-4 py-2.5 text-[var(--color-ink)] outline-none transition focus:border-[var(--color-verde)] focus:ring-2 focus:ring-[var(--color-sage)]"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Invia richiesta</button>
      </form>

      <div id="formSuccess" class="mt-4 hidden rounded-[var(--radius-md)] bg-[var(--color-sage)] px-5 py-4 text-[var(--color-verde)]">
        ✓ Messaggio inviato! Ti ricontatteremo presto.
      </div>
    </div>
  </section>

  <script>
    const phForm = document.getElementById('contactForm');
    if (phForm) {
      phForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = phForm.querySelector('button[type="submit"]');
        if (btn) { btn.disabled = true; btn.textContent = 'Invio…'; }
        try {
          const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(phForm) });
          const data = await res.json();
          if (data.success) {
            phForm.style.display = 'none';
            document.getElementById('formSuccess')?.classList.remove('hidden');
          } else {
            throw new Error('fail');
          }
        } catch {
          alert("Errore nell'invio. Riprova, oppure scrivici su WhatsApp o via email.");
          if (btn) { btn.disabled = false; btn.textContent = 'Invia richiesta'; }
        }
      });
    }
  </script>
</BaseLayout>
