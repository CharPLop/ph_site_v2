---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.bozza)).sort(
  (a, b) => b.data.data.getTime() - a.data.data.getTime()
);

const fmtData = (d: Date): string =>
  new Intl.DateTimeFormat("it-IT", { day: "numeric", month: "long", year: "numeric" }).format(d);
---

<BaseLayout
  title="Blog"
  description="Approfondimenti e articoli a cura dello studio Psiche Holos su psicologia, benessere, mindfulness e crescita personale."
  path="/blog/"
>
  <section class="container-ph max-w-4xl pt-16 md:pt-24">
    <p class="kicker">Approfondimenti</p>
    <h1 class="mt-3 text-[clamp(2.4rem,5vw,3.6rem)]">Blog</h1>
    <p class="mt-4 max-w-2xl text-[var(--color-ink-soft)]">
      Spunti e riflessioni sul benessere psicologico, a cura delle professioniste dello studio.
    </p>

    {posts.length === 0 ? (
      <p class="mt-12 text-[var(--color-ink-soft)]">
        Non ci sono ancora articoli pubblicati. Torna presto!
      </p>
    ) : (
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group flex flex-col overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-line)] bg-[var(--color-white-warm)] shadow-[var(--shadow-soft)] transition-transform duration-300 hover:-translate-y-1"
          >
            {post.data.copertina && (
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={post.data.copertina}
                  alt={post.data.copertinaAlt ?? post.data.titolo}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <time
                datetime={post.data.data.toISOString()}
                class="text-xs font-bold uppercase tracking-wider text-[var(--color-verde)]"
              >
                {fmtData(post.data.data)}
              </time>
              <h2 class="mt-2 font-[family-name:var(--font-display)] text-2xl text-[var(--color-ink)]">
                {post.data.titolo}
              </h2>
              <p class="mt-2 flex-1 text-[var(--color-ink-soft)]">{post.data.descrizione}</p>
              <span class="mt-4 font-semibold text-[var(--color-verde)]">Leggi l'articolo →</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
