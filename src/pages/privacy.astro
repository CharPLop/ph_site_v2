---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy & Cookie Policy"
  description="Informativa privacy e cookie dello studio Psiche Holos."
  path="/privacy/"
>
  <section class="container-ph max-w-3xl pt-16 md:pt-24">
    <h1 class="text-[clamp(2.2rem,4.5vw,3.2rem)]">Privacy & Cookie Policy</h1>
    <div class="mt-6 space-y-4 text-[var(--color-ink-soft)]">
      <p class="rounded-[var(--radius-sm)] bg-[var(--color-cream-deep)] p-4 text-sm">
        ⚠️ Contenuto da completare. Si può adattare l'informativa già presente su
        <code>ileniatagliaferro.it/privacy.html</code> al contesto dello studio
        Psiche Holos (titolare del trattamento, dati raccolti, base giuridica,
        cookie analitici, diritti dell'interessato).
      </p>
    </div>
  </section>
</BaseLayout>
